# ─── Majburiy ────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
BOT_USERNAME=fikraai_bot
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/fikra
JWT_SECRET=your_32_char_random_string
JWT_REFRESH_SECRET=another_32_char_random_string
NODE_ENV=development
PORT=3000

# ─── Web App URL'lari ─────────────────────────────────────────────────────────
# Telegram botdagi "Kirish" tugmasi shuni ochadi.
# Odatda FRONTEND_URL bilan bir xil bo'ladi.
FRONTEND_URL=https://your-app.railway.app
TELEGRAM_WEBAPP_URL=https://your-app.railway.app

# ─── AI xizmatlari ───────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AI...

# ─── Google OAuth (yangi v4) ─────────────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials orqali yarating
# https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: https://your-app.railway.app
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── Obuna va Admin ───────────────────────────────────────────────────────────
# STARS_WEBHOOK_SECRET — Telegram Stars to'lov v4'da olib tashlangan (P2P qoladi)
ADMIN_SECRET=strong_admin_panel_password
ADMIN_USERNAME=your_telegram_username
ADMIN_TELEGRAM_IDS=123456789,987654321
